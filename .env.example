# Backend server
PORT=3000
LOG_LEVEL=info

# Storage paths
STORAGE_ROOT=./storage
DB_PATH=./data/app.db

# Upload limits
MAX_UPLOAD_MB=50

# Pipeline / worker (M2)
PROCESS_CONCURRENCY=2
RENDER_DPI=150
# Leave empty to use pdftoppm / pdfinfo from PATH.
# Otherwise set to the directory that contains the poppler binaries
# (e.g. /opt/homebrew/bin on Apple Silicon).
POPPLER_BIN_PATH=

# OpenAI (M3): LLM for per-page script + title generation.
# 👉 Do NOT commit a real API key. Copy this file to .env and fill locally.
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4o-mini
# Script output language (BCP-47-ish label, only used in prompts).
OPENAI_SCRIPT_LANGUAGE=zh-TW
# Target per-page script length (allow ±20%). 150 ≈ 60 seconds of Mandarin speech.
OPENAI_SCRIPT_TARGET_CHARS=150
# Prompt style hint only (not enforced).
OPENAI_SCRIPT_STYLE=natural_spoken
# 把每頁投影片的 PNG 圖像也送給 LLM（需使用 vision 模型，如 gpt-4o-mini）。
OPENAI_SCRIPT_USE_IMAGES=true
# 送給 LLM 前先縮圖到這個寬度 (px)，避免 token 爆炸。
OPENAI_SCRIPT_IMAGE_MAX_WIDTH=1024
# 夾帶「上一頁腳本」作為銜接參考的最大字元數；過長會被截斷。
OPENAI_SCRIPT_PREV_CONTEXT_CHARS=400
# 夾帶「下一頁原文」作為銜接預告的最大字元數；過長會被截斷。
OPENAI_SCRIPT_NEXT_CONTEXT_CHARS=600
# OpenAI client knobs.
OPENAI_REQUEST_TIMEOUT_MS=240000
OPENAI_MAX_RETRIES=3
# Cost guardrail — refuse PDFs over this many pages before calling the LLM.
OPENAI_MAX_PAGES=50
OPENAI_IMAGE_MODEL=gpt-image-2
# Image quality: low / medium / high / auto
OPENAI_IMAGE_QUALITY=low
# Base timeout for image generation requests (ms)
OPENAI_IMAGE_TIMEOUT_MS=60000
# Timeout when quality is medium/high (ms)
OPENAI_IMAGE_TIMEOUT_MS_HIGH_QUALITY=120000

# OpenAI TTS (M4): per-page audio synthesis.
# Model: gpt-4o-mini-tts (default), tts-1, tts-1-hd
OPENAI_TTS_MODEL=gpt-4o-mini-tts
# Voice: alloy (default), ash, ballad, coral, echo, fable, onyx, nova, sage, shimmer, verse
OPENAI_TTS_VOICE=alloy
# Audio format (currently only mp3 is supported).
OPENAI_TTS_FORMAT=mp3
# Playback speed multiplier (0.25–4.0). 1.0 is natural.
OPENAI_TTS_SPEED=1.0
# How many TTS calls to run in parallel per PDF.
TTS_CONCURRENCY=2

# Google OAuth login (redirect URI defaults to /api/auth/google/callback on the current host)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
AUTH_SESSION_SECRET=change-me-to-a-long-random-string
