{
  "appId": "com.makeslide.app",
  "productName": "MakeSlide",
  "copyright": "Copyright © 2025 MakeSlide",
  "directories": {
    "output": "dist-electron",
    "buildResources": "build"
  },
  "files": [
    "electron-dist/**/*",
    "backend/dist/server.bundle.cjs",
    "frontend/dist/**/*",
    "package.json"
  ],
  "asar": false,
  "artifactName": "${productName}-${version}-win-x64.${ext}",
  "win": {
    "target": [
      { "target": "portable", "arch": ["x64"] },
      { "target": "zip",      "arch": ["x64"] }
    ],
    "icon": "build/icon.ico"
  },
  "mac": {
    "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
    "icon": "build/icon.icns"
  },
  "linux": {
    "target": [{ "target": "AppImage", "arch": ["x64"] }],
    "icon": "build/icon.png"
  }
}
