{
  "appId": "com.makeslide.app",
  "productName": "MakeSlide",
  "copyright": "Copyright © 2025 MakeSlide",
  "directories": {
    "output": "dist-electron",
    "buildResources": "build"
  },
  "files": [
    "electron-dist/**/*",
    "backend/dist/server.bundle.js",
    "frontend/dist/**/*",
    "package.json",
    "node_modules/better-sqlite3/**/*",
    "node_modules/sharp/**/*",
    "node_modules/@img/**/*",
    "node_modules/canvas/**/*",
    "node_modules/ffmpeg-static/**/*",
    "node_modules/pdfjs-dist/**/*"
  ],
  "asar": true,
  "asarUnpack": [
    "**/node_modules/ffmpeg-static/**",
    "**/node_modules/sharp/**",
    "**/node_modules/@img/**",
    "**/node_modules/better-sqlite3/**",
    "**/node_modules/canvas/**",
    "**/node_modules/pdfjs-dist/**"
  ],
  "artifactName": "${productName}-${version}-win-x64.${ext}",
  "win": {
    "target": [
      { "target": "nsis", "arch": ["x64"] },
      { "target": "zip",  "arch": ["x64"] }
    ],
    "icon": "build/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  },
  "mac": {
    "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
    "icon": "build/icon.icns"
  },
  "linux": {
    "target": [{ "target": "AppImage", "arch": ["x64"] }],
    "icon": "build/icon.png"
  }
}
