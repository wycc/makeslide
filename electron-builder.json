{
  "appId": "com.makeslide.app",
  "productName": "MakeSlide",
  "copyright": "Copyright © 2025 MakeSlide",
  "directories": {
    "output": "dist-electron",
    "buildResources": "build"
  },
  "files": [
    "electron-dist/**/*",
    "backend/dist/server.bundle.cjs",
    "frontend/dist/**/*",
    "package.json",
    { "from": "node_modules/better-sqlite3", "to": "node_modules/better-sqlite3" },
    { "from": "node_modules/sharp",          "to": "node_modules/sharp" },
    { "from": "node_modules/@img",           "to": "node_modules/@img" },
    { "from": "node_modules/canvas",         "to": "node_modules/canvas" },
    { "from": "node_modules/ffmpeg-static",  "to": "node_modules/ffmpeg-static" },
    { "from": "node_modules/pdfjs-dist",     "to": "node_modules/pdfjs-dist" }
  ],
  "asar": false,
  "artifactName": "${productName}-${version}-win-x64.${ext}",
  "win": {
    "target": [
      { "target": "nsis", "arch": ["x64"] },
      { "target": "zip",  "arch": ["x64"] }
    ],
    "icon": "build/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  },
  "mac": {
    "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
    "icon": "build/icon.icns"
  },
  "linux": {
    "target": [{ "target": "AppImage", "arch": ["x64"] }],
    "icon": "build/icon.png"
  }
}
