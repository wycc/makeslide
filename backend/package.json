{
  "name": "@makeslide/backend",
  "version": "1.1.1",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "../scripts/with-node-env.sh tsx watch src/server.ts",
    "build": "../scripts/with-node-env.sh tsc -p tsconfig.json",
    "build:bundle": "esbuild src/server.ts --bundle --platform=node --format=esm --outfile=dist/server.bundle.js --external:better-sqlite3 --external:sharp --external:@img --external:canvas --external:ffmpeg-static --external:\"pdfjs-dist/*\" --external:pdfjs-dist",
    "start": "../scripts/with-node-env.sh node dist/server.js",
    "typecheck": "../scripts/with-node-env.sh tsc --noEmit",
    "test": "../scripts/with-node-env.sh tsx --test ./test/*.test.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/static": "^7.0.4",
    "better-sqlite3": "^11.3.0",
    "canvas": "^3.2.3",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "ffmpeg-static": "^5.3.0",
    "music-metadata": "^11.12.3",
    "nanoid": "^5.0.7",
    "openai": "^6.35.0",
    "p-queue": "^9.2.0",
    "pdfjs-dist": "^4.10.38",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "sharp": "^0.34.5",
    "xlsx": "^0.18.5",
    "youtube-caption-extractor": "^1.7.8",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.10",
    "esbuild": "^0.27.7",
    "tsx": "^4.19.0",
    "typescript": "^5.5.3"
  }
}
